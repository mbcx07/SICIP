rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Usuarios ───────────────────────────────────────
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Admin only in production
    }

    // ─── Trabajadores ───────────────────────────────────
    match /trabajadores/{matricula} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Unidades ───────────────────────────────────────
    match /unidades/{unidadId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Tipos de Trámite (catálogo normativo) ──────────
    match /tipos_tramite/{tipoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Trámites ────────────────────────────────────────
    match /tramites/{tramiteId} {
      // TRABAJADOR: solo ve sus propios trámites
      allow read: if request.auth != null
        && (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'TRABAJADOR'
            ? resource.data.solicitanteUid == request.auth.uid
            : true);

      allow create: if request.auth != null
        && request.resource.data.solicitanteUid == request.auth.uid;

      allow update: if request.auth != null
        && (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ['AREA_PERSONAL', 'ADMIN']
            || resource.data.solicitanteUid == request.auth.uid);

      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'ADMIN';
    }

    // ─── Historial de Estados ───────────────────────────
    match /historial_estados/{historialId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Solo se agrega, no se modifica
    }

    // ─── Configuración ───────────────────────────────────
    match /configuracion/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
